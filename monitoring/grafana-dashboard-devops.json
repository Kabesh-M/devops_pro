        }
      },
      "targets": [
        {
          "expr": "sum(kube_deployment_status_replicas_available{deployment=\"devops-webapp\",namespace=\"devops-prod\"})",
          "refId": "A"
        }
      ],
      "title": "Available Replicas",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"devops-prod\",pod=~\"devops-webapp-.*\"}[5m]))",
          "legendFormat": "CPU",
          "refId": "A"
        }
      ],
      "title": "Webapp CPU Usage",
      "type": "timeseries"
    }
